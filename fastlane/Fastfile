default_platform(:android)

platform :android do
  desc "Build and distribute Android app to Firebase testers"
  lane :firebase_distribution do
    gradle(
      task: "assemble",
      build_type: "Debug"
    )

    firebase_app_distribution(
      app: ENV["FIREBASE_APP_ID"],
      groups: "qa-testers",
      release_notes: "POC build from GitHub Actions. Commit: #{ENV['GITHUB_SHA']}",
      apk_path: "app/build/outputs/apk/debug/app-debug.apk"
    )
  end
end